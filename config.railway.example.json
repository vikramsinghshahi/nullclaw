{
  "//_note": "Copy this file to config.railway.json and fill in real secrets (kept out of git by .gitignore). This is a minimal config for running nullclaw gateway + Telegram on Railway.",

  "default_temperature": 0.7,

  "models": {
    "providers": {
      "openrouter": {
        "api_key": "YOUR_OPENROUTER_API_KEY"
      }
    }
  },

  "agents": {
    "defaults": {
      "model": {
        "primary": "openrouter/anthropic/claude-sonnet-4"
      }
    }
  },

  "channels": {
    "cli": true,
    "telegram": {
      "accounts": {
        "main": {
          "bot_token": "YOUR_TELEGRAM_BOT_TOKEN",
          "allow_from": ["YOUR_TELEGRAM_USER_ID_OR_USERNAME"],
          "reply_in_private": true
        }
      }
    }
  },

  "memory": {
    "backend": "markdown",
    "auto_save": true
  },

  "gateway": {
    "port": 3000,
    "host": "::",
    "allow_public_bind": true
  }
}
